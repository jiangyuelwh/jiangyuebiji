  const filePath = path.resolve(ARTICLES_DIR, file);
  if (!safePath(filePath, ARTICLES_DIR)) return res.status(403).json({ error: '非法路径' });
  if (!fs.existsSync(filePath)) return res.status(404).json({ error: '文件不存在' });

  if (file.endsWith('.html')) {
    let html = fs.readFileSync(filePath, 'utf-8');
    const mdText = extractSourceMd(html);
    const newMdText = replaceMdLineTagAware(mdText, raw);
    if (!newMdText) return res.status(404).json({ error: '未找到对应任务行' });
    const title = extractTitle(newMdText);
    const bodyHtml = mdParse(newMdText, { breaks: true, gfm: true });
    const newHtml = buildHtml(title, bodyHtml, newMdText);
    try { fs.writeFileSync(filePath, newHtml, 'utf-8'); } catch (e) { return res.status(500).json({ error: '写入失败: ' + e.message }); }
    res.json({ success: true });
    return;
  }

  let content = fs.readFileSync(filePath, 'utf-8');
  const lines = content.split('\n');
  const oldRaw = /\[x\]/i.test(raw) ? raw.replace(/\[x\]/i, '[ ]') : raw.replace('[ ]', '[x]');
  const idx = findLineIdx(lines, oldRaw);
  if (idx === -1) return res.status(404).json({ error: '未找到对应任务行' });
  lines[idx] = raw;
  try { fs.writeFileSync(filePath, lines.join('\n'), 'utf-8'); } catch (e) { return res.status(500).json({ error: '写入失败: ' + e.message }); }
  res.json({ success: true });
});

