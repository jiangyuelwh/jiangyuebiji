// 从每日任务模板生成今日任务（前置插入到 今日任务.html）
app.post('/api/tasks/today/generate', (req, res) => {
  const now = new Date();
  const df = new Intl.DateTimeFormat('zh-CN', {timeZone:'Asia/Shanghai', year:'numeric', month:'2-digit', day:'2-digit'});
  const parts = df.formatToParts(now);
  const dateStr = parts.find(p=>p.type==='year').value + '-' + parts.find(p=>p.type==='month').value + '-' + parts.find(p=>p.type==='day').value;
  const weekdays = ['星期日','星期一','星期二','星期三','星期四','星期五','星期六'];
  const weekday = weekdays[now.getDay()];
  const dailyPath = path.join(ARTICLES_DIR, '任务管理/今日任务.html');
  const templatePath = path.join(ARTICLES_DIR, '任务管理/每日任务模板.html');

  if (!fs.existsSync(dailyPath)) return res.status(404).json({ error: '今日任务.html 不存在' });
  if (!fs.existsSync(templatePath)) return res.status(404).json({ error: '每日任务模板.html 不存在' });

  // 从 每日任务模板.html 的 source-md 读取模板项
  const templateHtml = fs.readFileSync(templatePath, 'utf-8');
  const templateMd = extractSourceMd(templateHtml);
  const items = [];
  for (const line of templateMd.split('\n')) {
    const m = line.match(/^- (.+)$/);
    if (m) items.push(m[1].trim());
  }
  if (items.length === 0) return res.status(400).json({ error: '模板中未找到任务项' });

  // 读取 今日任务.html
  let html = fs.readFileSync(dailyPath, 'utf-8');
  let mdText = extractSourceMd(html);

  // 去重检查：如果今日日期已在 source-md 中则跳过
  if (mdText.includes(dateStr)) {
    return res.status(409).json({ error: '今日任务已存在', date: dateStr });
  }

  // 天气表情（按时间段选）
  const hour = now.getHours();
  const weather = hour < 6 ? '🌙' : hour < 12 ? '🌞' : hour < 18 ? '⛅' : '🌆';

  // 构建新任务区
  const newLines = items.map(item => `- [ ] ${item} 📅 ${dateStr}%%每日任务%%`);
  const newSection = `${weather} ${dateStr} | ${weekday}\n🧘 今日计划\n${newLines.join('\n')}`;

  // 在 # 今日任务 标题后插入，旧内容移下去用 --- 分隔
  const headingMatch = mdText.match(/^(# .+)$/m);
  if (headingMatch) {
    const idx = headingMatch.index + headingMatch[0].length;
    mdText = mdText.substring(0, idx) + '\n\n' + newSection + '\n\n---\n\n' + mdText.substring(idx).trim();
  } else {
    mdText = mdText.trim() + '\n\n' + newSection;
  }

  // 重建并保存
  const title = extractTitle(mdText);
  const bodyHtml = mdParse(mdText, { breaks: true, gfm: true });
  const newHtml = buildHtml(title, bodyHtml, mdText);
  try {
    fs.writeFileSync(dailyPath, newHtml, 'utf-8');
    res.json({ success: true, count: items.length, date: dateStr });
  } catch (e) {
    res.status(500).json({ error: '写入失败: ' + e.message });
  }
});


