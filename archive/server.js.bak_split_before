// ── LRU 缓存 ──
class LRUCache {
  constructor(maxSize = 200, ttl = 30000) {
    this.maxSize = maxSize; this.ttl = ttl;
    this.cache = new Map();
  }
  get(key) {
    if (!this.cache.has(key)) return null;
    const entry = this.cache.get(key);
    if (Date.now() - entry.time > this.ttl) { this.cache.delete(key); return null; }
    this.cache.delete(key); this.cache.set(key, entry);
    return entry.value;
  }
  set(key, value) {
    if (this.cache.has(key)) this.cache.delete(key);
    if (this.cache.size >= this.maxSize) { this.cache.delete(this.cache.keys().next().value); }
    this.cache.set(key, { value, time: Date.now() });
  }
  del(key) { this.cache.delete(key); }
  clear() { this.cache.clear(); }
  delPrefix(prefix) { for (const k of this.cache.keys()) if (k.startsWith(prefix)) this.cache.delete(k); }
}
const fileCache = new LRUCache(200, 30000);
const dirCache = new LRUCache(50, 10000);

//   - **粗体** 关闭**前是中文标点时失败（如 **粗体。**文本 ❌）
//   - __粗体__ 和 _斜体_ 在中文环境完全不工作
// 预处理修复所有这些边缘情况，不影响原生英文格式。
function preprocessMd(md) {
  // 1. **bold** 粗体：修复关闭**前是中文全角标点（\uff00-\uffef）的情况
  md = md.replace(/\*\*(\S[^*]*?[\u4e00-\u9fff\u3000-\u303f\uff00-\uffef])\*\*/g, '<strong>$1</strong>');
  // 2. __bold__ 粗体（中文环境marked完全不识别）
  md = md.replace(/__(.+?)__/g, (m, inner) => {
    if (/[\u4e00-\u9fff\u3000-\u303f\uff00-\uffef]/.test(inner)) return '<strong>' + inner + '</strong>';
    return m;
  });
  // 3. _italic_ 斜体（中文环境marked不识别）
  md = md.replace(/_([^_]+?)_/g, (m, inner) => {
    if (/[\u4e00-\u9fff\u3000-\u303f\uff00-\uffef]/.test(inner)) return '<em>' + inner + '</em>';
    return m;
  });
  return md;
}

const mdParse = (text, opts) => marked.parse(preprocessMd(text || ''), opts);

