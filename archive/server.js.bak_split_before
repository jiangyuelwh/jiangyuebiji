app.post('/api/move', (req, res) => {
  const { path: itemPath, targetDir } = req.body;
  if (!itemPath || targetDir === undefined) return res.status(400).json({ error: '缺少参数' });
  const srcFull = path.resolve(ARTICLES_DIR, itemPath);
  if (!safePath(srcFull, ARTICLES_DIR)) return res.status(403).json({ error: '非法路径' });
  if (!fs.existsSync(srcFull)) return res.status(404).json({ error: '源文件不存在' });
  const dstDir = targetDir ? path.resolve(ARTICLES_DIR, targetDir) : ARTICLES_DIR;
  if (!safePath(dstDir, ARTICLES_DIR)) return res.status(403).json({ error: '目标目录非法' });
  fs.mkdirSync(dstDir, { recursive: true });
  const baseName = path.basename(srcFull);
  let dstFull = path.join(dstDir, baseName);
  if (fs.existsSync(dstFull)) {
    const ext = path.extname(baseName);
    const stem = path.basename(baseName, ext);
    let c = 1;
    while (fs.existsSync(path.join(dstDir, stem + '_' + c + ext))) c++;
    dstFull = path.join(dstDir, stem + '_' + c + ext);
  }
  try { fs.renameSync(srcFull, dstFull); } catch (e) { return res.status(500).json({ error: '移动失败: ' + e.message }); }
  dirCache.del('tree'); fileCache.del(srcFull);
  res.json({ success: true, path: path.relative(ARTICLES_DIR, dstFull).replace(/\\/g, '/') });
});
