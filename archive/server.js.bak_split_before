// ── HTML 标记 ──
// 注意：必须是一个连续的注释块，中间内容才不会出现在DOM中
const MD_START = '<!--source-md';
const MD_END = '/source-md-->';

// 检查一行是否包含指定标签（兼容旧格式 <!-- 标签 --> 和新格式 %%标签%%）
function hasTag(line, tag) {
  return line.includes('<!-- ' + tag + ' -->') || line.includes('%%' + tag + '%%');
}

// 在 source-md 行中忽略 HTML 注释标签进行匹配（兼容页面JS不发送标签的场景）
// 找到匹配行后，如果 raw 不带标签但源行有，自动保留原标签
function replaceMdLineTagAware(mdText, raw) {
  const oldRaw = /\[x\]/i.test(raw) ? raw.replace(/\[x\]/i, '[ ]') : raw.replace('[ ]', '[x]');
  const lines = mdText.split('\n');
  const strippedOld = oldRaw.replace(/<!--[\s\S]*?-->/g, '').trim();
  for (let i = 0; i < lines.length; i++) {
    if (lines[i].replace(/<!--[\s\S]*?-->/g, '').trim() === strippedOld) {
      // 保留源行的标签（如果 raw 没有标签而源行有）
      const tagMatch = lines[i].match(/<!--[\s\S]*?-->/);
      let newLine = raw;
      if (tagMatch && !raw.includes('<!--')) {
        newLine = raw.trim() + ' ' + tagMatch[0];
      }
      lines[i] = newLine;
      return lines.join('\n');
    }
  }
  return null;
}

// ── 版本历史 ──
const HISTORY_DIR = path.join(BASE_DIR, '.history');
function saveSnapshot(filePath) {
  try {
    if (!fs.existsSync(filePath)) return;
    const relPath = path.relative(ARTICLES_DIR, filePath);
    const timestamp = new Date().toISOString().replace(/[:.]/g, '-');
    const histPath = path.join(HISTORY_DIR, relPath + '.' + timestamp);
    fs.mkdirSync(path.dirname(histPath), { recursive: true });
    fs.copyFileSync(filePath, histPath);
    const baseDir = path.dirname(histPath);
    const snapshots = fs.readdirSync(baseDir).filter(f => f.startsWith(path.basename(relPath))).sort();
    while (snapshots.length > 50) { try { fs.unlinkSync(path.join(baseDir, snapshots.shift())); } catch {} }
  } catch (e) { console.error('快照保存失败:', e.message); }
}

// ── Hook 系统 ──
const EventEmitter = require('events');
class HookSystem extends EventEmitter {
  register(name, fn) { this.on(name, fn); }
  async trigger(name, ...args) {
    for (const fn of this.listeners(name)) { try { await fn(...args); } catch (e) { console.error('Hook '+name+':', e.message); } }
  }
}
const hooks = new HookSystem();

// ── 标签系统 ──
function extractTags(mdText) {
  const tags = [];
  const m = mdText.match(/<!--\s*tags?\s*:\s*(.+?)\s*-->/i);
  if (m) tags.push(...m[1].split(/[,，、\s]+/).filter(Boolean));
  return [...new Set(tags)];
}
function escapeRegex(s) { return s.replace(/[.*+?^${}()|[\]\\]/g, '\\$&'); }
// 纯文件（.md）的精确行匹配，忽略标签
function findLineIdx(lines, target) {
  const stripped = target.replace(/<!--[\s\S]*?-->/g, '').trim();
  for (let i = 0; i < lines.length; i++) {
    if (lines[i].replace(/<!--[\s\S]*?-->/g, '').trim() === stripped) return i;
  }
  return -1;
}

function buildHtml(title, bodyHtml, sourceMd) {
  const esc = s => String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  // 提取 sourceMd 中的 <script> 标签，放到 </article> 之后（避免 turndown 转换时过滤）
  const scriptBlocks = [];
  sourceMd.replace(/<script[\s\S]*?<\/script>/gi, (m) => { scriptBlocks.push(m); return ''; });
  const scriptHtml = scriptBlocks.join('\n');
  // 去掉 bodyHtml 中已有的 <script>（来自 mdParse 保留的内联 HTML），避免重复
  const cleanBody = bodyHtml.replace(/<script[\s\S]*?<\/script>/gi, '');
  // 将 %%标签%% 转为 HTML 注释（使标签在渲染页面中不可见）
  const visibleBody = cleanBody
    .replace(/%%提醒事项%%/g, '<!-- 提醒事项 -->')
    .replace(/%%每日任务%%/g, '<!-- 每日任务 -->')
    .replace(/%%每日任务模板%%/g, '<!-- 每日任务模板 -->');
  return '<!DOCTYPE html>\n'
    + '<html lang="zh-CN">\n<head>\n'
    + '<meta charset="utf-8">\n'
    + '<meta name="viewport" content="width=device-width, initial-scale=1">\n'
    + '<title>' + esc(title) + '</title>\n'
    + '<link rel="stylesheet" href="/static/github-markdown.min.css">\n'
    + '<style>\n  body { margin:0; background:#fff; }\n'
    + '  .markdown-body { box-sizing: border-box; min-width: 200px; max-width: 860px; margin: 0 auto; padding: 45px; }\n'
    + '  @media (max-width:767px) { .markdown-body { padding: 15px; } }\n'
    + '</style>\n</head>\n<body>\n'
    + '<article class="markdown-body">' + visibleBody + '</article>\n'
+ '<button onclick="copyLink(this)" style="position:fixed;top:8px;right:8px;z-index:999;border:1px solid #e0e0e0;background:#fff;border-radius:6px;padding:4px 10px;cursor:pointer;font-size:13px;box-shadow:0 1px 4px rgba(0,0,0,0.08);line-height:1" title="复制文章链接">\n'
+ '  🔗\n'
+ '</button>\n'
+ '<script>function copyLink(b){navigator.clipboard.writeText(window.location.href).then(function(){b.innerHTML="\\u2713 \\u5df2\\u590d\\u5236";setTimeout(function(){b.innerHTML="\\ud83d\\udd17"},2000)}).catch(function(){b.innerHTML="\\u2717 \\u590d\\u5236\\u5931\\u8d25"})}</script>\n'
+ (scriptHtml ? scriptHtml + '\n' : '')
    + '</body>\n</html>\n'
    + MD_START + '\n' + sourceMd + '\n' + MD_END;
}

function extractSourceMd(html) {
  // 新格式：<!--source-md\n content\n /source-md--> 单个连续注释
  const newMatch = html.match(/<!--source-md\s*([\s\S]*?)\s*\/source-md-->/);
  if (newMatch) return newMatch[1].trim();
  // 旧格式（兼容）: <!--source-md-->\n content\n <!--/source-md-->
  const oldMatch = html.match(/<!--source-md-->([\s\S]*?)<!--\/source-md-->/);
  if (oldMatch) return oldMatch[1].trim();
  // Fallback: from title
  const tm = html.match(/<title>(.+?)<\/title>/);
  const title = tm ? tm[1] : '无标题';
  return '# ' + title + '\n\n<!-- markdown源丢失 -->\n';
}

// 确保 HTML 有 Markdown 源，没有则用 turndown 转换并嵌入
function escHtml(s) {
  return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

function ensureSourceMd(html) {
  // 检查是否有 source-md（新旧格式都支持）
  if (/<!--source-md[\s\S]*?\/source-md-->/.test(html)) return html;
  if (/<!--source-md-->[\s\S]*?<!--\/source-md-->/.test(html)) return html;

  // 提取 <body> 中的 <script> 标签，避免 turndown 过滤掉
  const scriptBlocks = [];
  const bodyMatchAll = html.match(/<body[^>]*>([\s\S]*)<\/body>/i);
  if (bodyMatchAll) {
    bodyMatchAll[1].replace(/<script[\s\S]*?<\/script>/gi, (m) => { scriptBlocks.push(m); });
  }

  // 用 turndown 将 HTML body 转为 Markdown
  let mdText = '';
  try {
    // 提取 <body> 或 <article> 或完整内容
    const bodyMatch = html.match(/<body[^>]*>([\s\S]*)<\/body>/i);
    const articleMatch = html.match(/<article[^>]*>([\s\S]*)<\/article>/i);
    const bodyContent = articleMatch ? articleMatch[1] : (bodyMatch ? bodyMatch[1] : html);
    mdText = turndown.turndown(bodyContent).trim();
  } catch {
    const tm = html.match(/<title>(.+?)<\/title>/);
    const title = tm ? tm[1] : '无标题';
    mdText = '# ' + title + '\n\n> 自动从 HTML 转换\n';
  }

  // 如果提取到了 script，附加到 markdown 末尾
  if (scriptBlocks.length > 0) {
    mdText += '\n\n' + scriptBlocks.join('\n');
  }

  // 取出 title
  const tm = html.match(/<title>(.+?)<\/title>/);
  const title = tm ? tm[1] : '无标题';

  // 确保 markdown 有标题行（# 标题），否则从 HTML <title> 补上
  if (!/^#\s/m.test(mdText)) {
    mdText = '# ' + title + '\n\n' + mdText;
  }

  // 重新构建：保留原始 <style> 等头部信息，body 内渲染 md
  const bodyHtml = mdParse(mdText, { breaks: true, gfm: true });

  // 保留原有 <head> 内容，替换 body
  const headContent = html.match(/<head[^>]*>([\s\S]*)<\/head>/i);
  const headHtml = headContent ? headContent[1] : '';

  return '<!DOCTYPE html>\n<html lang="zh-CN">\n<head>\n'
    + '<meta charset="utf-8">\n'
    + '<meta name="viewport" content="width=device-width, initial-scale=1">\n'
    + '<title>' + escHtml(title) + '</title>\n'
    + '<link rel="stylesheet" href="/static/github-markdown.min.css">\n'
    + '<style>\n  body { margin:0; background:#fff; }\n'
    + '  .markdown-body { box-sizing: border-box; min-width: 200px; max-width: 860px; margin: 0 auto; padding: 45px; }\n'
    + '  @media (max-width:767px) { .markdown-body { padding: 15px; } }\n'
    + '</style>\n</head>\n<body>\n'
    + '<article class="markdown-body">' + bodyHtml + '</article>\n'
    + '</body>\n</html>\n'
    + MD_START + '\n' + mdText + '\n' + MD_END;
}

function extractTitle(md) {
  const m = md.match(/^#\s+(.+)$/m);
  return m ? m[1].trim() : '无标题';
}

function slugify(text) {
  return String(text).replace(/[\\/:*?"<>|]/g, '').replace(/\s+/g, '_').slice(0, 60) || 'untitled';
}

function safePath(target, base) {
  return path.resolve(base, target).startsWith(path.resolve(base));
}

// ── 扫描目录树 ──
function scanTree(dirPath) {
  const tree = [];
  let entries;
  try { entries = fs.readdirSync(dirPath).sort(); } catch { return tree; }
  for (const entry of entries) {
    if (entry.startsWith('.')) continue;
    const fullPath = path.join(dirPath, entry);
    const stat = fs.statSync(fullPath);
    if (!stat.isDirectory()) continue;
    tree.push({
      type: 'dir', name: entry,
      path: path.relative(ARTICLES_DIR, fullPath).replace(/\\/g, '/'),
      children: scanTree(fullPath),
    });
  }
  return tree;
}

// ── 列出文件 ──
function listDir(dirPath) {
  const files = [];
  let entries;
  try { entries = fs.readdirSync(dirPath).sort(); } catch { return files; }
  for (const entry of entries) {
    if (entry.startsWith('.')) continue;
    const fullPath = path.join(dirPath, entry);
    const stat = fs.statSync(fullPath);
    if (stat.isDirectory()) continue;
    if (!entry.endsWith('.html') && !entry.endsWith('.md')) continue;

    let title = entry.replace(/\.html$/, '').replace(/\.md$/, '');
    let isMd = entry.endsWith('.md');
    try {
      const content = fs.readFileSync(fullPath, 'utf-8').slice(0, 2000);
      const tm = content.match(/<title>(.+?)<\/title>/);
      if (tm && tm[1] && tm[1] !== '无标题') title = tm[1];
    } catch {}

    files.push({
      name: entry,
      path: path.relative(ARTICLES_DIR, fullPath).replace(/\\/g, '/'),
      title,
      size: stat.size,
      mtime: stat.mtime.toISOString().replace('T', ' ').slice(0, 19),
      isMd: !!isMd,
    });
  }
  return files;
}

