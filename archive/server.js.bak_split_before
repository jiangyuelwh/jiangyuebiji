app.get('/api/list', (req, res) => {
  const dirPath = req.query.dir || '';
  const target = dirPath ? path.join(ARTICLES_DIR, dirPath) : ARTICLES_DIR;
  if (!fs.existsSync(target)) return res.status(404).json({ error: '目录不存在' });
  res.json({ files: listDir(target), path: dirPath || '/' });
});

app.get('/api/read', (req, res) => {
  const p = req.query.path;
  if (!p) return res.status(400).json({ error: '缺少 path' });
  const filePath = path.resolve(ARTICLES_DIR, p);
  if (!safePath(filePath, ARTICLES_DIR)) return res.status(403).json({ error: '非法路径' });
  var cached = fileCache.get(filePath);
  if (cached) return res.json(cached);
  if (!fs.existsSync(filePath)) return res.status(404).json({ error: '文件不存在' });
  let html = fs.readFileSync(filePath, 'utf-8');
  // 没有 source-md 则自动转换并保存回文件
  if (html.indexOf(MD_START) < 0) {
    html = ensureSourceMd(html);
    try { fs.writeFileSync(filePath, html, 'utf-8'); } catch (e) { /* 只读文件，不保存 */ }
  }
  const mdText = extractSourceMd(html);
  res.json({ path: p, title: extractTitle(mdText), markdown: mdText });
});

app.post('/api/save', (req, res) => {
  const { markdown: mdText, path: filePath } = req.body;
  let htmlPath;
  if (filePath) {
    htmlPath = path.resolve(ARTICLES_DIR, filePath);
    if (!safePath(htmlPath, ARTICLES_DIR)) return res.status(403).json({ error: '非法路径' });
  } else {
    const title = extractTitle(mdText || '');
    const slug = slugify(title);
    const dateStr = new Date().toISOString().slice(0, 10).replace(/-/g, '');
    const targetDir = path.join(ARTICLES_DIR, dateStr);
    fs.mkdirSync(targetDir, { recursive: true });
    let baseName = slug + '.html';
    htmlPath = path.join(targetDir, baseName);
    let c = 1;
    while (fs.existsSync(htmlPath)) { baseName = slug + '_' + c + '.html'; htmlPath = path.join(targetDir, baseName); c++; }
  }
  const title = extractTitle(mdText || '');
  const bodyHtml = mdParse(mdText || '', { breaks: true, gfm: true });
  try {
    fs.writeFileSync(htmlPath, buildHtml(title, bodyHtml, mdText || ''), 'utf-8');
  } catch (e) { return res.status(500).json({ error: '写入失败: ' + e.message }); }
  const relPath = path.relative(ARTICLES_DIR, htmlPath).replace(/\\\\/g, '/');
  res.json({ success: true, path: relPath, title });
    hooks.trigger('afterSave', { filePath: filePath });
});

app.post('/api/create-file', (req, res) => {
  let { name, dir, content: initialContent } = req.body;
  if (!name) return res.status(400).json({ error: '缺少文件名' });
  if (!name.endsWith('.html')) name += '.html';
  const targetDir = dir ? path.join(ARTICLES_DIR, dir) : ARTICLES_DIR;
  if (!safePath(targetDir, ARTICLES_DIR)) return res.status(403).json({ error: '非法路径' });
  fs.mkdirSync(targetDir, { recursive: true });
  let filePath = path.join(targetDir, name);
  if (fs.existsSync(filePath)) {
    const base = name.replace(/\.html$/, '');
    let c = 1;
    while (fs.existsSync(path.join(targetDir, base + '_' + c + '.html'))) c++;
    filePath = path.join(targetDir, base + '_' + c + '.html');
    name = base + '_' + c + '.html';
  }
  const mdText = initialContent || '# ' + name.replace(/\.html$/, '') + '\n\n';
  const title = extractTitle(mdText);
  const bodyHtml = mdParse(mdText, { breaks: true, gfm: true });
    dirCache.del('tree');
  try { fs.writeFileSync(filePath, buildHtml(title, bodyHtml, mdText), 'utf-8'); } catch (e) { return res.status(500).json({ error: '写入失败: ' + e.message }); }
  const relPath = path.relative(ARTICLES_DIR, filePath).replace(/\\\\/g, '/');
  res.json({ success: true, path: relPath, name });
});

app.post('/api/create-dir', (req, res) => {
  const { name, dir } = req.body;
  if (!name) return res.status(400).json({ error: '缺少目录名' });
  const targetDir = dir ? path.join(ARTICLES_DIR, dir, name) : path.join(ARTICLES_DIR, name);
  if (!safePath(targetDir, ARTICLES_DIR)) return res.status(403).json({ error: '非法路径' });
  fs.mkdirSync(targetDir, { recursive: true });
  res.json({ success: true, path: path.relative(ARTICLES_DIR, targetDir).replace(/\\/g, '/') });
});

app.post('/api/upload', (req, res) => {
  const { files: uploadedFiles, dir } = req.body;
  if (!uploadedFiles || !Array.isArray(uploadedFiles)) return res.status(400).json({ error: '缺少 files 数组' });
  const targetDir = dir ? path.join(ARTICLES_DIR, dir) : ARTICLES_DIR;
  if (!safePath(targetDir, ARTICLES_DIR)) return res.status(403).json({ error: '非法路径' });
  fs.mkdirSync(targetDir, { recursive: true });
  const results = [];
  for (const file of uploadedFiles) {
    let { name: fileName, content: fileContent } = file;
    if (!fileName) continue;
    if (fileName.endsWith('.md')) {
      const title = extractTitle(fileContent);
      const bodyHtml = mdParse(fileContent, { breaks: true, gfm: true });
      fileName = fileName.replace(/\.md$/, '.html');
      fileContent = buildHtml(title, bodyHtml, fileContent);
    } else if (!fileName.endsWith('.html')) continue;
    let filePath = path.join(targetDir, fileName);
    let finalName = fileName;
    if (fs.existsSync(filePath)) {
      const base = fileName.replace(/\.html$/, '');
      let c = 1;
      while (fs.existsSync(path.join(targetDir, base + '_' + c + '.html'))) c++;
      filePath = path.join(targetDir, base + '_' + c + '.html');
      finalName = base + '_' + c + '.html';
    }
    try {
      fs.writeFileSync(filePath, fileContent, 'utf-8');
      results.push({ name: finalName, path: path.relative(ARTICLES_DIR, filePath).replace(/\\/g, '/') });
    } catch (err) {
      results.push({ name: finalName, path: null, error: err.code });
    }
  }
    dirCache.del('tree');
    fileCache.del(filePath);
    dirCache.del('tree');
    fileCache.del(filePath);
  res.json({ success: true, files: results });
});

app.post('/api/delete', (req, res) => {
  const { path: p, isDir } = req.body;
  if (!p) return res.status(400).json({ error: '缺少 path' });
  const target = path.resolve(ARTICLES_DIR, p);
  if (!safePath(target, ARTICLES_DIR)) return res.status(403).json({ error: '非法路径' });
  if (isDir) { try { fs.rmSync(target, { recursive: true, force: true }); } catch {} }
  else { try { if (fs.existsSync(target)) fs.unlinkSync(target); } catch {} }
  res.json({ success: true });
});

app.post('/api/rename', (req, res) => {
  const { path: oldPath, name: newName } = req.body;
  if (!oldPath || !newName) return res.status(400).json({ error: '缺少参数' });
  const oldFull = path.resolve(ARTICLES_DIR, oldPath);
  if (!safePath(oldFull, ARTICLES_DIR)) return res.status(403).json({ error: '非法路径' });
  const dirName = path.dirname(oldFull);
  const newFull = path.join(dirName, newName);
  if (fs.existsSync(newFull)) return res.status(409).json({ error: '目标已存在' });
  fs.renameSync(oldFull, newFull);
  dirCache.del('tree'); fileCache.del(oldFull);
