app.get("/api/tags", function(req, res) {
  var tag = (req.query.tag || "").trim();
  var results = [];
  function walk(dir, prefix) {
    var entries;
    try { entries = fs.readdirSync(dir, { withFileTypes: true }); } catch(e) { return; }
    for (var i = 0; i < entries.length; i++) {
      var entry = entries[i];
      if (entry.name.startsWith('.')) continue;
      var full = path.join(dir, entry.name);
      var rel = prefix ? prefix + '/' + entry.name : entry.name;
      if (entry.isDirectory()) { walk(full, rel); continue; }
      if (!entry.name.endsWith('.html') && !entry.name.endsWith('.md')) continue;
      try {
        var c = fs.readFileSync(full, 'utf-8');
        var tags = extractTags(c);
        if (!tag || tags.some(function(t) { return t.toLowerCase().includes(tag.toLowerCase()); })) {
          var title = entry.name.replace(/\.(html|md)$/, '');
          var tm = c.match(/<title>(.+?)<\/title>/i);
          if (tm) title = tm[1];
          results.push({ name: entry.name, path: rel, title: title, tags: tags });
        }
      } catch(e) {}
    }
  }
  walk(ARTICLES_DIR, '');
  if (!tag) {
    var allTags = [...new Set(results.flatMap(function(r) { return r.tags; }))].sort();
    return res.json({ tags: allTags });
  }
  res.json({ files: results.slice(0, 50) });
});


// history api
app.get("/api/history", function(req, res) {
  var p = req.query.path;
  if (!p) return res.status(400).json({ error: "missing path" });
  var relPath = p.replace(/^\/+/g, "");
  var histDir = path.join(HISTORY_DIR, relPath);
  if (!fs.existsSync(histDir)) return res.json({ versions: [] });
  var snapshots = fs.readdirSync(histDir)
    .filter(function(f) { return f.startsWith(path.basename(relPath)); })
    .sort().reverse().slice(0, 50)
    .map(function(f) {
      var ts = f.split(".").slice(1).join(".");
      var size = fs.statSync(path.join(histDir, f)).size;
      return { file: f, time: ts.replace(/-/g, ":").replace(/T/, " ").replace(/Z$/, ""), size: size };
    });
  res.json({ versions: snapshots });
});

